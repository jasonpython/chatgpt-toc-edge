{
  "manifest_version": 3,
  "name": "ChatGPT实时对话目录与快速导航",
  "version": "1.1.3",
  "description": "在ChatGPT网页右侧生成实时对话目录，支持搜索、拖动、锚点链接、Markdown/JSON导出和快速跳转。",
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    }
  ]
}